#!/usr/bin/env bash

dir=`dirname $0`

wrapped="$dir"/../share/submit-seriatim.py

raw="$dir"/../passim/seriatim.py

if [ -f "$raw" ]; then
    script="$raw"
else
    script="$wrapped"
fi

export SPARK_CONF_DIR="$dir"/../conf

SPARK_SUBMIT_ARGS="$SPARK_SUBMIT_ARGS"

spark-submit \
    --packages 'io.graphframes:graphframes-spark4_2.13:0.9.3' \
    $SPARK_SUBMIT_ARGS \
    "$script" "$@"
